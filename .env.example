# ─── Styra Virtual Try-On Studio ───────────────────────────────────────────
# Copy this file to .env.local and fill in your real values.
# Never commit .env.local to version control (it is gitignored).
#
# KEY SECURITY RULES:
#   - Only VITE_* variables are bundled into the browser. Keep them non-secret.
#   - STRIPE_SECRET_KEY and STRIPE_WEBHOOK_SECRET must be set as Supabase
#     edge function secrets — never put them here or in .env.local.
#     Command: npx supabase secrets set KEY=value --project-ref <ref>

# ── Frontend-safe (exposed to browser bundle) ─────────────────────────────
# n8n webhook endpoint for AI image merging
VITE_WEBHOOK_URL=

# Supabase project (publishable keys — safe to expose)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Stripe payment link URL (safe — just a URL, not a secret)
VITE_STRIPE_PAYMENT_LINK=
