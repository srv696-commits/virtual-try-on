# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/

# ─── Build output ─────────────────────────────────────────────────────────────
dist/
dist-ssr/

# ─── Environment variables — never commit ────────────────────────────────────
.env
.env.local
.env.*.local

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ─── Editor & IDE ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Screenshots & local assets ───────────────────────────────────────────────
*.png
*.jpg
*.jpeg
*.gif
*.webp
# Exception: keep any images intentionally in src/assets
!src/assets/**
# Exception: Shop-the-Look catalog served from /public/catalog
!public/catalog/**

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.local
.cache/
.temp/

# mcp servers
.mcp.json

# playwright test artifacts
.playwright-mcp/